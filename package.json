{
  "name": "slot-flight-workspace",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/typescript"
  ],
  "scripts": {
    "build": "bun run --filter slot-flight build",
    "check": "bun run --filter slot-flight check",
    "fix": "bun run --filter slot-flight fix",
    "format": "bun run --filter slot-flight format",
    "lint": "bun run --filter slot-flight lint",
    "test": "bun run --filter slot-flight test && PYTHONPATH=packages/python/src python3 -m unittest discover -s packages/python/tests",
    "test:python": "PYTHONPATH=packages/python/src python3 -m unittest discover -s packages/python/tests",
    "test:typescript": "bun run --filter slot-flight test",
    "typecheck": "bun run --filter slot-flight typecheck"
  }
}
